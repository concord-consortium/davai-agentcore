# Provider API keys — each may be a literal key (local dev) OR a Secrets Manager ARN.
# LLM calls go DIRECT to the provider (not through Bedrock), matching the old server.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Optional: LangSmith tracing (literal key or Secrets Manager ARN)
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=davai-agentcore

# Optional: shared bearer secret (parity with old server). If unset, /invocations is open (local dev).
DAVAI_API_SECRET=

# Server
PORT=8080
# Region used only when resolving a Secrets Manager ARN without a region in the ARN.
AWS_REGION=us-east-1
