{
  "name": "davai-agentcore-backend",
  "version": "0.1.0",
  "description": "DAVAI agent re-hosted on AWS Bedrock AgentCore (BYO container). LangGraph-JS agent + in-VM checkpointer, /invocations + /ping (+ /ws in P3).",
  "private": true,
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --target=node22 --packages=external --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "test:ws": "node scripts/run-ws-smoke.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-secrets-manager": "^3.857.0",
    "@langchain/anthropic": "^1.5",
    "@langchain/core": "^1.2",
    "@langchain/google-genai": "^2.2",
    "@langchain/langgraph": "^1.4",
    "@langchain/langgraph-checkpoint": "^1.1",
    "@langchain/openai": "^1.5",
    "dotenv": "^16.6.1",
    "langsmith": "^0.3.63",
    "nanoid": "^5.0.9",
    "ws": "^8.21.0",
    "zod": "^3.25.48"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.25.8",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3"
  }
}
